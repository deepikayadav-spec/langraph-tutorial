# Copy this file to .env and fill in your keys.
# .env is already in .gitignore — never commit real keys.

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required only for real LLMs (ChatOpenAI, GPT-4o, etc.)
# Not needed for MockChatModel used in this tutorial
OPENAI_API_KEY=sk-...

# ── LangSmith observability ───────────────────────────────────────────────────
# Sign up free at https://smith.langchain.com
# Settings → API Keys → Create → copy the key below
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=langsmith-demo
